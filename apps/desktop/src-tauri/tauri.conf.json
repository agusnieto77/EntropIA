{
  "productName": "EntropIA",
  "version": "0.0.1",
  "identifier": "com.entropia.app",
  "build": {
    "beforeDevCommand": "pnpm --filter @entropia/desktop download-ocr-models && pnpm --filter @entropia/desktop dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "EntropIA",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": true,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**/*"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"],
    "resources": ["resources/text-detection.rten", "resources/text-recognition.rten", "resources/*"]
  }
}
